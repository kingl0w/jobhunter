# --- Required ---
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Shared password your buddies type in to sign in. Set to a long random string.
APP_PASSWORD=changeme

# Used to sign session cookies. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=dev-secret-change-me

# --- Origins / CORS ---
# Comma-separated list of allowed origins. Include the URL the frontend is served from.
CORS_ORIGINS=http://localhost:3000

# Set to true behind HTTPS so cookies are only sent over TLS.
COOKIE_SECURE=false

# --- Sync schedule ---
SYNC_INTERVAL_HOURS=6
MAX_RESULTS_PER_SOURCE=25
HOURS_OLD=72

# --- Per-user daily LLM quota ---
DAILY_TAILOR_LIMIT=30
DAILY_SUMMARIZE_LIMIT=60

# --- Optional: error reporting ---
# SENTRY_DSN=

# --- Optional: backups (in-process; runs daily) ---
BACKUP_KEEP_DAYS=14

# --- Optional: demo mode ---
# When true, a 'demo' user with seeded data is auto-created. AI features and edits are blocked for demo accounts.
DEMO_MODE=false

# --- Optional: daily email digest ---
# Leave SMTP_HOST empty to disable email digests.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=jobhunter@example.com
# DIGEST_HOUR_UTC=13
